# GlitchTip Environment Variables
# Kopieren nach .env und ausfüllen

# Postgres-Passwort (stark wählen)
POSTGRES_PASSWORD=changeme_strong_password

# Django Secret Key (min. 50 Zeichen zufällig)
SECRET_KEY=changeme_very_long_random_secret_key_min_50_chars

# GlitchTip Domain (ohne trailing slash)
GLITCHTIP_DOMAIN=https://errors.lyrvio.com

# Admin-Account (beim ersten Start automatisch angelegt)
ADMIN_EMAIL=admin@lyrvio.com
ADMIN_PASSWORD=changeme_admin_password

# Email-Versand via Resend SMTP
# Format: smtp+tls://user:password@host:port
EMAIL_URL=smtp+tls://resend:re_XXXXX@smtp.resend.com:587
DEFAULT_FROM_EMAIL=errors@lyrvio.com
