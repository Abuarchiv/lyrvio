{
  "name": "lyrvio",
  "version": "0.0.1",
  "private": true,
  "description": "24/7 Wohnungs-Bewerbungs-Bot für deutsche Großstädte",
  "workspaces": [
    "web",
    "api",
    "bot",
    "scrapers",
    "db",
    "templates"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:bot": "pnpm --filter bot dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter='!web' test && pnpm --filter web test:e2e",
    "test:unit": "pnpm -r --filter='!web' test",
    "test:e2e": "pnpm --filter web test:e2e"
  },
  "packageManager": "pnpm@9.0.0"
}
